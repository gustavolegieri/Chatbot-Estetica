# Banco — Supabase + Vercel: ver docs/SUPABASE-VERCEL.md
# Runtime (app + Vercel): porta 6543 no host db.*.supabase.co
# Vercel (IPv4): pooler — postgres.SEU_REF @ aws-*-REGIAO.pooler.supabase.com:6543
# DATABASE_URL=postgresql://postgres.SEU_REF:SENHA@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
# PC migrations: DIRECT_URL=postgresql://postgres:SENHA@db.SEU_REF.supabase.co:5432/postgres?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/estetica_automotiva?schema=public"

# Autenticação (gere com: openssl rand -base64 32)
JWT_SECRET="sua-chave-secreta-muito-segura-aqui"

# URL pública da aplicação (webhooks WhatsApp)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WasenderAPI (WhatsApp) — Substitui Evolution API
# Obtenha sua chave em: https://wasenderapi.com
WASENDER_API_KEY="sua-chave-wasender-api"

# Evolution API (legado) — pode ser removido se usar WasenderAPI
# EVOLUTION_API_URL="http://localhost:8080"
# EVOLUTION_API_KEY="sua-api-key"
# EVOLUTION_INSTANCE_NAME="estetica"

# Cron de lembretes 24h (chame GET /api/cron/reminders a cada hora)
CRON_SECRET="gere-uma-chave-aleatoria"

# Cerebras AI — interpretação de mensagens e respostas a dúvidas no WhatsApp
CEREBRAS_API_KEY="sua-chave-cerebras"
CEREBRAS_MODEL="gpt-oss-120b"

# Distance Matrix Dashboard
DISTANCEMATRIX_API_KEY="sua-chave-distance-matrix"
# Compatibilidade com a antiga variável
GOOGLE_MAPS_API_KEY="sua-chave-google-maps"
