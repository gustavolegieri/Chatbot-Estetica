generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum FinancialType {
  INCOME
  EXPENSE
}

enum FinancialCategory {
  SERVICE
  PRODUCT
  SALARY
  RENT
  UTILITIES
  SUPPLIES
  OTHER
}

enum WhatsAppSessionStep {
  IDLE
  CHOOSING_SERVICE
  CHOOSING_DATE
  CHOOSING_TIME
  CONFIRMING
  RESCHEDULING
  CANCELLING
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageSender {
  CLIENT
  BOT
  ADMIN
}

enum HandoffStatus {
  NONE
  PENDING
  IN_PROGRESS
  RESOLVED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(OPERATOR)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  financialRecords FinancialRecord[]
}

model Client {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  email        String?
  vehiclePlate String?
  vehicleModel String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  appointments     Appointment[]
  whatsappSessions WhatsAppSession[]
  whatsappMessages WhatsAppMessage[]
}

model Service {
  id              String   @id @default(cuid())
  name            String
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  durationMin     Int      @default(60)
  active          Boolean  @default(true)
  catalogKey      String?  @unique
  categoryNum     Int?
  menuOrder       Int      @default(0)
  whatsappPitch   String?
  whatsappShort   String?
  whatsappDetail  String?  @db.Text
  priceHatchMin   Decimal? @db.Decimal(10, 2)
  priceHatchMax   Decimal? @db.Decimal(10, 2)
  priceSuvMin     Decimal? @db.Decimal(10, 2)
  priceSuvMax     Decimal? @db.Decimal(10, 2)
  timeEstimate    String?
  upsellServiceId String?
  upsellBenefit   String?
  showInWhatsApp  Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  upsellService    Service?  @relation("ServiceUpsell", fields: [upsellServiceId], references: [id], onDelete: SetNull)
  upsellFor        Service[] @relation("ServiceUpsell")
  appointments     Appointment[]
  financialRecords FinancialRecord[]
}

model Appointment {
  id        String            @id @default(cuid())
  clientId  String
  serviceId String
  date      DateTime
  startTime String
  endTime   String
  status          AppointmentStatus @default(PENDING)
  notes           String?
  source          String            @default("admin")
  reminderSentAt         DateTime?
  reminder4hSentAt       DateTime?
  confirmWarningSentAt   DateTime?
  clientConfirmedAt      DateTime?
  createdAt              DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  client           Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service          Service           @relation(fields: [serviceId], references: [id])
  financialRecords FinancialRecord[]

  @@index([date])
  @@index([clientId])
  @@index([status])
}

model FinancialRecord {
  id            String            @id @default(cuid())
  type          FinancialType
  category      FinancialCategory @default(OTHER)
  amount        Decimal           @db.Decimal(10, 2)
  description   String
  date          DateTime          @default(now())
  appointmentId String?
  serviceId     String?
  userId        String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  service     Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([type])
}

model Settings {
  id                    String  @id @default("default")
  businessName          String  @default("Estética Automotiva")
  businessPhone         String?
  businessAddress       String?
  businessHoursStart    String  @default("08:00")
  businessHoursEnd      String  @default("18:00")
  lunchBreakStart       String?
  lunchBreakEnd         String?
  slotDurationMin       Int     @default(60)
  workingDays           String  @default("1,2,3,4,5,6")
  whatsappEnabled       Boolean @default(true)
  whatsappWelcomeMsg    String  @default("Olá! Bem-vindo à nossa estética automotiva. Como posso ajudar?")
  evolutionApiUrl       String?
  evolutionApiKey       String?
  evolutionInstanceName String?
  pixKey                String?
  pixHolderName         String?
  pixBank               String?
  sessionResetMin       Int     @default(60)
  followupIdleMin       Int     @default(10)
  reminder4hMin         Int     @default(240)
  reminder30minMin      Int     @default(30)
  autoCancelMin         Int     @default(10)
  updatedAt             DateTime @updatedAt
}

model BotPrompt {
  key       String   @id
  label     String
  category  String   @default("geral")
  content   String   @db.Text
  hint      String?
  updatedAt DateTime @updatedAt
}

model BlockedDate {
  id         String   @id @default(cuid())
  date       DateTime @db.Date
  reason     String
  isHoliday  Boolean  @default(false)
  blockStart String?
  blockEnd   String?
  createdAt  DateTime @default(now())

  @@unique([date])
}

model WhatsAppSession {
  id                   String              @id @default(cuid())
  clientId             String?
  phone                String              @unique
  step                 WhatsAppSessionStep @default(IDLE)
  selectedServiceId    String?
  selectedDate         String?
  selectedTime         String?
  pendingAppointmentId String?
  metadata             Json?
  handoffStatus        HandoffStatus       @default(NONE)
  handoffAt            DateTime?
  handoffReason        String?
  handoffNote          String?
  handoffResolvedAt    DateTime?
  botPaused            Boolean             @default(false)
  lastMessageAt        DateTime?
  lastMessagePreview   String?
  unreadCount          Int                 @default(0)
  updatedAt            DateTime            @updatedAt
  createdAt            DateTime            @default(now())

  client   Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  messages WhatsAppMessage[]

  @@index([handoffStatus])
  @@index([lastMessageAt])
  @@index([updatedAt])
}

model WhatsAppMessage {
  id        String           @id @default(cuid())
  sessionId String?
  phone     String
  clientId  String?
  direction MessageDirection
  sender    MessageSender
  body      String           @db.Text
  flowStage String?
  createdAt DateTime         @default(now())

  session WhatsAppSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  client  Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([phone])
  @@index([sessionId])
  @@index([createdAt])
  @@index([clientId])
}
