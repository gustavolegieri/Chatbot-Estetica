generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String
  password         String
  role             UserRole          @default(OPERATOR)
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  financialRecords FinancialRecord[]
}

model Client {
  id                String             @id @default(cuid())
  name              String
  phone             String             @unique
  email             String?
  vehiclePlate      String?
  vehicleModel      String?
  notes             String?
  address           String?
  addressLat        Decimal?           @db.Decimal(10, 7)
  addressLng        Decimal?           @db.Decimal(10, 7)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  appointments      Appointment[]
  couponRedemptions CouponRedemption[]
  whatsappMessages  WhatsAppMessage[]
  whatsappSessions  WhatsAppSession[]
}

model Service {
  id               String            @id @default(cuid())
  name             String
  description      String?
  price            Decimal           @db.Decimal(10, 2)
  durationMin      Int               @default(60)
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  catalogKey       String?           @unique
  categoryNum      Int?
  menuOrder        Int               @default(0)
  priceHatchMax    Decimal?          @db.Decimal(10, 2)
  priceHatchMin    Decimal?          @db.Decimal(10, 2)
  priceSuvMax      Decimal?          @db.Decimal(10, 2)
  priceSuvMin      Decimal?          @db.Decimal(10, 2)
  showInWhatsApp   Boolean           @default(true)
  timeEstimate     String?
  upsellBenefit    String?
  upsellServiceId  String?
  whatsappDetail   String?
  whatsappPitch    String?
  whatsappShort    String?
  // Upsell inteligente por tipo de veículo
  upsellForHatchback Boolean          @default(false)
  upsellForSedan   Boolean          @default(false)
  upsellForSuv     Boolean          @default(false)
  upsellForPickup  Boolean          @default(false)
  upsellDiscount   Decimal?          @db.Decimal(10, 2) // Desconto ao aceitar upsell
  appointments     Appointment[]
  financialRecords FinancialRecord[]
  upsellService    Service?          @relation("ServiceUpsell", fields: [upsellServiceId], references: [id])
  upsellFor        Service[]         @relation("ServiceUpsell")
  media            ServiceMedia[]
}

model Appointment {
  id                    String            @id @default(cuid())
  clientId              String
  serviceId             String
  date                  DateTime
  startTime             String
  endTime               String
  status                AppointmentStatus @default(PENDING)
  notes                 String?
  source                String            @default("admin")
  reminderSentAt        DateTime?
  reminder4hSentAt      DateTime?
  reminder30minSentAt  DateTime?
  reminder1hSentAt      DateTime?
  reminder1daySentAt    DateTime?
  confirmWarningSentAt  DateTime?
  clientConfirmedAt     DateTime?
  needsPickup           Boolean           @default(false)
  needsReturn           Boolean           @default(false)
  pickupAddress         String?
  pickupDistanceKm      Decimal?          @db.Decimal(6, 2)
  pickupFee             Decimal?          @db.Decimal(10, 2)
  couponId              String?
  couponDiscount        Decimal?          @db.Decimal(10, 2)
  finalPrice            Decimal?          @db.Decimal(10, 2)
  // Payment fields (simulated)
  paymentStatus         PaymentStatus     @default(PENDING)
  paymentGateway        PaymentGateway    @default(CASH)
  paymentMethod         String? // "PIX", "CARTAO", "DINHEIRO"
  transactionId         String?
  paidAt                DateTime?
  paymentSimulationCode String? // Código para simular pagamento no test-bot
  reminderPreference    String? // "30min", "1hour", "1day", "none"
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  client                Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service               Service           @relation(fields: [serviceId], references: [id])
  coupon                Coupon?           @relation(fields: [couponId], references: [id])
  financialRecords      FinancialRecord[]

  @@index([date])
  @@index([clientId])
  @@index([status])
  @@index([paymentStatus])
}

model FinancialRecord {
  id            String            @id @default(cuid())
  type          FinancialType
  category      FinancialCategory @default(OTHER)
  amount        Decimal           @db.Decimal(10, 2)
  description   String
  date          DateTime          @default(now())
  appointmentId String?
  serviceId     String?
  userId        String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  appointment   Appointment?      @relation(fields: [appointmentId], references: [id])
  service       Service?          @relation(fields: [serviceId], references: [id])
  user          User?             @relation(fields: [userId], references: [id])

  @@index([date])
  @@index([type])
}

model Settings {
  id                    String         @id @default("default")
  businessName          String         @default("Estética Automotiva")
  businessPhone         String?
  businessAddress       String?
  storeAddress          String         @default("Rua Professor Benedito Loureiro de Lima, 146, Jardim Esplanada, Jundiaí, SP")
  storeLat              Decimal?       @db.Decimal(10, 7)
  storeLng              Decimal?       @db.Decimal(10, 7)
  pickupDeliveryEnabled Boolean        @default(true)
  pickupFeePerKm        Decimal        @default(2.50) @db.Decimal(10, 2)
  pickupFeeBase         Decimal        @default(0) @db.Decimal(10, 2)
  pickupMaxDistanceKm   Int?
  businessHoursStart    String         @default("08:00")
  businessHoursEnd      String         @default("18:00")
  slotDurationMin       Int            @default(60)
  workingDays           String         @default("1,2,3,4,5,6")
  whatsappEnabled       Boolean        @default(true)
  whatsappWelcomeMsg    String         @default("Olá! Bem-vindo à nossa estética automotiva. Como posso ajudar?")
  evolutionApiUrl       String?
  evolutionApiKey       String?
  evolutionInstanceName String?
  pixKey                String?
  pixHolderName         String?
  pixBank               String?
  pixMerchantCity       String? @default("Jundiai")
  pixQrCodeImage        String?
  updatedAt             DateTime       @updatedAt
  autoCancelMin         Int            @default(10)
  followupIdleMin       Int            @default(10)
  lunchBreakEnd         String?
  lunchBreakStart       String?
  reminder30minMin      Int            @default(30)
  reminder4hMin         Int            @default(240)
  sessionResetMin       Int            @default(30)
  testModeEnabled       Boolean        @default(false)
  testModePhone         String?
  businessHours         BusinessHour[]
}

model BusinessHour {
  id         String   @id @default(cuid())
  dayOfWeek  Int // 0 = Sunday, 1 = Monday, etc.
  openTime   String // "08:00"
  closeTime  String // "18:00"
  isOpen     Boolean  @default(true)
  settingsId String   @default("default")
  settings   Settings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([settingsId, dayOfWeek])
}

model Brand {
  id          String   @id @default("default")
  displayName String?
  themeColor  String?
  logoPath    String?
  updatedAt   DateTime @updatedAt
}

model NotificationSetting {
  id                         String   @id @default("default")
  notifyNewAppointment       Boolean  @default(true)
  notifyClientHandoff        Boolean  @default(true)
  notifyCancelledAppointment Boolean  @default(true)
  notifyMonthlyGoal          Boolean  @default(false)
  monthlyGoalAmount          Decimal? @db.Decimal(10, 2)
  notifyByEmail              Boolean  @default(false)
  notifyEmailAddress         String?
  updatedAt                  DateTime @updatedAt
}

model Coupon {
  id               String             @id @default(cuid())
  code             String             @unique
  type             String             @default("percent")
  amount           Decimal            @db.Decimal(10, 2)
  validFrom        DateTime?
  validTo          DateTime?
  usageLimit       Int?
  usagePerCustomer Int?               @default(1)
  active           Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  redemptions      CouponRedemption[]
  appointments     Appointment[]
}

model CouponRedemption {
  id            String   @id @default(cuid())
  couponId      String
  clientId      String
  appointmentId String?
  amountApplied Decimal? @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  coupon        Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([clientId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String
  data      Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model ServiceMedia {
  id        String   @id @default(cuid())
  serviceId String?
  filename  String
  path      String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
  service   Service? @relation(fields: [serviceId], references: [id])

  @@index([serviceId])
}

model BotPrompt {
  key       String   @id
  label     String
  category  String   @default("geral")
  content   String
  hint      String?
  updatedAt DateTime @updatedAt
}

model BlockedDate {
  id         String   @id @default(cuid())
  date       DateTime @unique @db.Date
  reason     String
  isHoliday  Boolean  @default(false)
  blockStart String?
  blockEnd   String?
  createdAt  DateTime @default(now())
}

model BlockedPhone {
  id        String   @id @default(cuid())
  phone     String   @unique
  reason    String   @default("Bloqueado pelo administrador")
  createdAt DateTime @default(now())
}

model WhatsAppSession {
  id                   String              @id @default(cuid())
  clientId             String?
  phone                String              @unique
  step                 WhatsAppSessionStep @default(IDLE)
  selectedServiceId    String?
  selectedDate         String?
  selectedTime         String?
  pendingAppointmentId String?
  metadata             Json?
  updatedAt            DateTime            @updatedAt
  createdAt            DateTime            @default(now())
  botPaused            Boolean             @default(false)
  handoffAt            DateTime?
  handoffNote          String?
  handoffReason        String?
  handoffResolvedAt    DateTime?
  handoffStatus        HandoffStatus       @default(NONE)
  lastMessageAt        DateTime?
  lastMessagePreview   String?
  
  // Funil de conversão
  abandonmentStage     String?
  abandonmentReason    String?
  abandonmentAt        DateTime?
  lastStage            String?
  funnelSteps          Json?               @default("{}") // Rastrear passos no funil
  
  // Sistema de desconto
  discountOffer        Json?               @default("{}") // Oferta de desconto para cancelamento
  unreadCount          Int                 @default(0)
  messages             WhatsAppMessage[]
  client               Client?             @relation(fields: [clientId], references: [id])
  stageTransitions     StageTransition[]

  @@index([handoffStatus])
  @@index([lastMessageAt])
  @@index([updatedAt])
}

model WhatsAppMessage {
  id        String           @id @default(cuid())
  sessionId String?
  phone     String
  clientId  String?
  direction MessageDirection
  sender    MessageSender
  body      String
  flowStage String?
  createdAt DateTime         @default(now())
  client    Client?          @relation(fields: [clientId], references: [id])
  session   WhatsAppSession? @relation(fields: [sessionId], references: [id])

  @@index([phone])
  @@index([sessionId])
  @@index([createdAt])
  @@index([clientId])
}

model Campaign {
  id              String          @id @default(cuid())
  name            String
  message         String
  selectorType    String
  selectorMeta    Json?
  status          CampaignStatus  @default(DRAFT)
  totalRecipients Int?
  successCount    Int             @default(0)
  failCount       Int             @default(0)
  createdById     String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  queue           CampaignQueue[]
}

model CampaignQueue {
  id         String      @id @default(cuid())
  campaignId String
  phone      String
  name       String?
  status     QueueStatus @default(PENDING)
  attempts   Int         @default(0)
  lastError  String?
  queuedAt   DateTime    @default(now())
  sentAt     DateTime?
  campaign   Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([status])
}

enum UserRole {
  ADMIN
  OPERATOR
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  FAILED
  REFUNDED
}

enum PaymentGateway {
  CASH
  PIX
  CARD
  MANUAL
}

enum FinancialType {
  INCOME
  EXPENSE
}

enum FinancialCategory {
  SERVICE
  PRODUCT
  SALARY
  RENT
  UTILITIES
  SUPPLIES
  OTHER
}

enum WhatsAppSessionStep {
  IDLE
  CHOOSING_SERVICE
  CHOOSING_DATE
  CHOOSING_TIME
  ASKING_COUPON
  ASKING_PICKUP
  ASKING_PICKUP_ADDRESS
  ASKING_RETURN_PREFERENCE
  CONFIRMING
  RESCHEDULING
  CANCELLING
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageSender {
  CLIENT
  BOT
  ADMIN
}

enum HandoffStatus {
  NONE
  PENDING
  IN_PROGRESS
  RESOLVED
}

enum CampaignStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

enum QueueStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

model StageTransition {
  id              String          @id @default(cuid())
  sessionId       String
  stage           String
  message         String
  timestamp       DateTime        @default(now())
  completed       Boolean         @default(false)
  whatsappSession WhatsAppSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([timestamp])
}
